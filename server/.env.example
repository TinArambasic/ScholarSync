# MongoDB connection string
# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/student_forum
# Atlas MongoDB:
# MONGODB_URI=mongodb+srv://<username>:<url_encoded_password>@scholarsync.xf9enlh.mongodb.net/?retryWrites=true&w=majority&appName=ScholarSync
MONGODB_URI=

# Database name (required if your URI does not include one)
MONGODB_DB_NAME=student_forum

# Server port
PORT=4000

# Allowed frontend origin(s), comma-separated
# Example: CORS_ORIGIN=https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# JWT secret for token signing (change this in production!)
JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars

# OpenAI API key (required for AI "Predloži odgovor" feature)
OPENAI_API_KEY=

# Optional: override default OpenAI model
OPENAI_MODEL=gpt-4.1-mini

# Optional: set to 'production' in production
NODE_ENV=development
